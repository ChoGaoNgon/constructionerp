  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "node -e \"const { spawn } = require('child_process'); const args = process.argv.slice(1).filter(a => a !== '--host' && a !== '0.0.0.0' && a !== '--port' && a !== '3000'); spawn('next', ['dev', '-p', '3000', '-H', '0.0.0.0'], { stdio: 'inherit', shell: true })\"",
    "build": "next build",
    "start": "next start -p 3000",
    "lint": "next lint"
  },
  "dependencies": {
    "@google/genai": "^1.29.0",
